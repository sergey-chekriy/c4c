        <bounds x="170" y="40" width="180" height="80"/>
        <sourceConnection xsi:type="archimate:Connection" id="id-c4c-connection-m84-tech-1" source="id-c4c-viewobject-m84-tech-runtime" target="id-c4c-viewobject-m84-tech-dexArtifact" archimateRelationship="id-c4c-relationship-7">
