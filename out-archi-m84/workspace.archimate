    </element>
    <element xsi:type="archimate:ArchimateDiagramModel" name="M84 motivation" id="id-c4c-view-m84-motivation" connectionRouterType="2">
      <child xsi:type="archimate:DiagramObject" id="id-c4c-viewobject-m84-motivation-riskGoal" archimateElement="id-c4c-element-riskGoal" type="1" fillColor="#ccccff">
