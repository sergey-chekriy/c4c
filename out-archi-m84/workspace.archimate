          <bendpoint startX="0" startY="-40" endX="-200" endY="-1260"/>
          <bendpoint startX="200" startY="-40" endX="0" endY="-1260"/>
        </sourceConnection>
        <sourceConnection xsi:type="archimate:Connection" id="id-c4c-connection-m84-app-4" source="id-c4c-viewobject-m84-app-gateway" target="id-c4c-viewobject-m84-app-matcher" archimateRelationship="id-c4c-relationship-4">
          <bendpoint startX="0" startY="-10" endX="-200" endY="-1490"/>
