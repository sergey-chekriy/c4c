      <child xsi:type="archimate:DiagramObject" id="id-c4c-viewobject-m84-app-dex" archimateElement="id-c4c-element-dex" type="1" fillColor="#008e00" fontColor="#ffffff" targetConnections="id-c4c-connection-m84-app-8">
        <bounds x="500" y="820" width="180" height="80"/>
        <sourceConnection xsi:type="archimate:Connection" id="id-c4c-connection-m84-app-7" source="id-c4c-viewobject-m84-app-dex" target="id-c4c-viewobject-m84-app-gateway" archimateRelationship="id-c4c-relationship-11">
          <bendpoint startX="0" startY="-620" endX="200" endY="80"/>
          <bendpoint startX="-200" startY="-620" endX="0" endY="80"/>
