      <child xsi:type="archimate:DiagramObject" id="id-c4c-viewobject-m84-app-gateway" archimateElement="id-c4c-element-gateway" type="1" fillColor="#008e00" targetConnections="id-c4c-connection-m84-app-7">
        <bounds x="300" y="120" width="180" height="80"/>
