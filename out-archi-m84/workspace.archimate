        <bounds x="500" y="40" width="180" height="80"/>
        <sourceConnection xsi:type="archimate:Connection" id="id-c4c-connection-m84-app-1" source="id-c4c-viewobject-m84-app-operator" target="id-c4c-viewobject-m84-app-onboarding" archimateRelationship="id-c4c-relationship-rAssignment">
        </sourceConnection>
      </child>
      <child xsi:type="archimate:DiagramObject" id="id-c4c-viewobject-m84-app-onboarding" archimateElement="id-c4c-element-onboarding" type="1" fillColor="#ffffb5" targetConnections="id-c4c-connection-m84-app-1">
