<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="M84 ArchiMate Conformance" id="id-c4c-model" version="5.0.0">
  <folder name="Strategy" id="id-c4c-folder-strategy" type="strategy">
    <element xsi:type="archimate:Capability" name="Digital asset trading" id="id-c4c-element-tradingCapability"/>
  </folder>
  <folder name="Business" id="id-c4c-folder-business" type="business">
    <element xsi:type="archimate:BusinessActor" name="Operator" id="id-c4c-element-operator"/>
    <element xsi:type="archimate:BusinessProcess" name="Customer onboarding" id="id-c4c-element-onboarding"/>
    <element xsi:type="archimate:BusinessObject" name="Customer record" id="id-c4c-element-customerRecord"/>
  </folder>
  <folder name="Application" id="id-c4c-folder-application" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="DEX Application" id="id-c4c-element-dex"/>
    <element xsi:type="archimate:ApplicationComponent" name="Internal API Gateway" id="id-c4c-element-gateway"/>
    <element xsi:type="archimate:ApplicationService" name="Trading API" id="id-c4c-element-api"/>
    <element xsi:type="archimate:ApplicationFunction" name="Order Matcher" id="id-c4c-element-matcher"/>
    <element xsi:type="archimate:DataObject" name="Ledger Entry" id="id-c4c-element-ledger"/>
  </folder>
  <folder name="Technology &amp; Physical" id="id-c4c-folder-technology" type="technology">
    <element xsi:type="archimate:Node" name="Primary Node" id="id-c4c-element-runtime"/>
    <element xsi:type="archimate:Artifact" name="DEX Artifact" id="id-c4c-element-dexArtifact"/>
    <element xsi:type="archimate:Equipment" name="Rack" id="id-c4c-element-rack"/>
  </folder>
  <folder name="Motivation" id="id-c4c-folder-motivation" type="motivation">
    <element xsi:type="archimate:Goal" name="Reduce settlement risk" id="id-c4c-element-riskGoal"/>
  </folder>
  <folder name="Implementation &amp; Migration" id="id-c4c-folder-implementation_migration" type="implementation_migration">
    <element xsi:type="archimate:WorkPackage" name="DEX delivery" id="id-c4c-element-delivery"/>
    <element xsi:type="archimate:Deliverable" name="Trading platform" id="id-c4c-element-platform"/>
  </folder>
  <folder name="Other" id="id-c4c-folder-other" type="other">
    <element xsi:type="archimate:Junction" name="Order accepted" id="id-c4c-element-andJoin"/>
    <element xsi:type="archimate:Junction" name="Settlement alternative" id="id-c4c-element-orJoin"/>
  </folder>
  <folder name="Relations" id="id-c4c-folder-relations" type="relations">
    <element xsi:type="archimate:AssignmentRelationship" id="id-c4c-relationship-rAssignment" source="id-c4c-element-operator" target="id-c4c-element-onboarding" name="performs"/>
    <element xsi:type="archimate:AccessRelationship" id="id-c4c-relationship-2" source="id-c4c-element-onboarding" target="id-c4c-element-customerRecord" name="reads"/>
    <element xsi:type="archimate:ServingRelationship" id="id-c4c-relationship-3" source="id-c4c-element-gateway" target="id-c4c-element-api" name="serves"/>
    <element xsi:type="archimate:TriggeringRelationship" id="id-c4c-relationship-4" source="id-c4c-element-gateway" target="id-c4c-element-matcher" name="triggers"/>
    <element xsi:type="archimate:AccessRelationship" id="id-c4c-relationship-5" source="id-c4c-element-matcher" target="id-c4c-element-ledger" name="writes"/>
    <element xsi:type="archimate:FlowRelationship" id="id-c4c-relationship-6" source="id-c4c-element-matcher" target="id-c4c-element-api" name="publishes orders"/>
    <element xsi:type="archimate:AssignmentRelationship" id="id-c4c-relationship-7" source="id-c4c-element-runtime" target="id-c4c-element-dexArtifact" name="hosts"/>
    <element xsi:type="archimate:RealizationRelationship" id="id-c4c-relationship-8" source="id-c4c-element-tradingCapability" target="id-c4c-element-dex" name="realized by"/>
    <element xsi:type="archimate:InfluenceRelationship" id="id-c4c-relationship-9" source="id-c4c-element-riskGoal" target="id-c4c-element-tradingCapability" name="influences"/>
    <element xsi:type="archimate:RealizationRelationship" id="id-c4c-relationship-10" source="id-c4c-element-delivery" target="id-c4c-element-platform" name="produces"/>
    <element xsi:type="archimate:CompositionRelationship" id="id-c4c-relationship-11" source="id-c4c-element-dex" target="id-c4c-element-gateway" name="contains"/>
    <element xsi:type="archimate:AggregationRelationship" id="id-c4c-relationship-12" source="id-c4c-element-gateway" target="id-c4c-element-dex" name="part of platform"/>
    <element xsi:type="archimate:FlowRelationship" id="id-c4c-relationship-13" source="id-c4c-element-api" target="id-c4c-element-andJoin" name="accepted by"/>
    <element xsi:type="archimate:FlowRelationship" id="id-c4c-relationship-14" source="id-c4c-element-andJoin" target="id-c4c-element-orJoin" name="routes to"/>
    <element xsi:type="archimate:FlowRelationship" id="id-c4c-relationship-15" source="id-c4c-element-orJoin" target="id-c4c-element-ledger" name="settles"/>
    <element xsi:type="archimate:AssociationRelationship" id="id-c4c-relationship-16" source="id-c4c-element-gateway" target="id-c4c-element-operator" name="notifies"/>
  </folder>
  <folder name="Views" id="id-c4c-folder-diagrams" type="diagrams">
    <element xsi:type="archimate:ArchimateDiagramModel" name="M84 application cooperation" id="id-c4c-view-m84-app" connectionRouterType="2">
