        </sourceConnection>
      </child>
      <child xsi:type="archimate:DiagramObject" id="id-c4c-viewobject-m84-app-ledger" archimateElement="id-c4c-element-ledger" type="1" fillColor="#b5ffff" targetConnections="id-c4c-connection-m84-app-5 id-c4c-connection-m84-app-11">
        <bounds x="600" y="120" width="180" height="80"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="id-c4c-viewobject-m84-app-andJoin" archimateElement="id-c4c-element-andJoin" type="1" fillColor="#eeeeee" targetConnections="id-c4c-connection-m84-app-9">
