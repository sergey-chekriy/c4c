        <sourceConnection xsi:type="archimate:Connection" id="id-c4c-connection-m84-app-8" source="id-c4c-viewobject-m84-app-gateway" target="id-c4c-viewobject-m84-app-dex" archimateRelationship="id-c4c-relationship-12">
          <bendpoint startX="0" startY="110" endX="-200" endY="-590"/>
          <bendpoint startX="200" startY="110" endX="0" endY="-590"/>
        </sourceConnection>
        <sourceConnection xsi:type="archimate:Connection" id="id-c4c-connection-m84-app-12" source="id-c4c-viewobject-m84-app-gateway" target="id-c4c-viewobject-m84-app-operator" archimateRelationship="id-c4c-relationship-16">
        </sourceConnection>
      </child>
      <child xsi:type="archimate:DiagramObject" id="id-c4c-viewobject-m84-app-api" archimateElement="id-c4c-element-api" type="1" fillColor="#b5ffff" targetConnections="id-c4c-connection-m84-app-3 id-c4c-connection-m84-app-6">
        <bounds x="500" y="1340" width="180" height="80"/>
        <sourceConnection xsi:type="archimate:Connection" id="id-c4c-connection-m84-app-9" source="id-c4c-viewobject-m84-app-api" target="id-c4c-viewobject-m84-app-andJoin" archimateRelationship="id-c4c-relationship-13">
          <bendpoint startX="0" startY="-1080" endX="0" endY="-1860"/>
