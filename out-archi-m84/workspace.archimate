        </sourceConnection>
      </child>
      <child xsi:type="archimate:DiagramObject" id="id-c4c-viewobject-m84-app-matcher" archimateElement="id-c4c-element-matcher" type="1" fillColor="#b5ffff" targetConnections="id-c4c-connection-m84-app-4">
        <bounds x="500" y="1600" width="180" height="80"/>
        <sourceConnection xsi:type="archimate:Connection" id="id-c4c-connection-m84-app-5" source="id-c4c-viewobject-m84-app-matcher" target="id-c4c-viewobject-m84-app-ledger" archimateRelationship="id-c4c-relationship-5">
