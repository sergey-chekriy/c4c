<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="M85 ArchiMate Views Layout" id="id-c4c-model" version="5.0.0">
  <folder name="Strategy" id="id-c4c-folder-strategy" type="strategy">
    <element xsi:type="archimate:Capability" name="Digital asset trading" id="id-c4c-element-tradingCapability"/>
  </folder>
  <folder name="Business" id="id-c4c-folder-business" type="business">
    <element xsi:type="archimate:BusinessActor" name="Operator" id="id-c4c-element-operator"/>
    <element xsi:type="archimate:BusinessProcess" name="Client Onboarding" id="id-c4c-element-onboarding"/>
  </folder>
  <folder name="Application" id="id-c4c-folder-application" type="application">
    <element xsi:type="archimate:ApplicationService" name="Trading API Service" id="id-c4c-element-apiService"/>
    <element xsi:type="archimate:ApplicationComponent" name="Client Portal" id="id-c4c-element-portal"/>
    <element xsi:type="archimate:ApplicationComponent" name="Internal API Gateway" id="id-c4c-element-gateway"/>
    <element xsi:type="archimate:ApplicationFunction" name="Order Matcher" id="id-c4c-element-matcher"/>
    <element xsi:type="archimate:DataObject" name="Ledger Entry" id="id-c4c-element-ledger"/>
    <element xsi:type="archimate:ApplicationComponent" name="Audit Trail" id="id-c4c-element-audit"/>
  </folder>
  <folder name="Technology &amp; Physical" id="id-c4c-folder-technology" type="technology">
    <element xsi:type="archimate:TechnologyService" name="Runtime Service" id="id-c4c-element-techService"/>
    <element xsi:type="archimate:Node" name="Primary Runtime Node" id="id-c4c-element-runtime"/>
    <element xsi:type="archimate:Artifact" name="Gateway Artifact" id="id-c4c-element-gatewayArtifact"/>
    <element xsi:type="archimate:Equipment" name="Rack A" id="id-c4c-element-rack"/>
  </folder>
  <folder name="Motivation" id="id-c4c-folder-motivation" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Compliance" id="id-c4c-element-compliance"/>
    <element xsi:type="archimate:Driver" name="Regulatory pressure" id="id-c4c-element-regulation"/>
    <element xsi:type="archimate:Goal" name="Traceable settlement" id="id-c4c-element-traceabilityGoal"/>
    <element xsi:type="archimate:Requirement" name="Every order is auditable" id="id-c4c-element-auditRequirement"/>
  </folder>
  <folder name="Implementation &amp; Migration" id="id-c4c-folder-implementation_migration" type="implementation_migration">
  </folder>
  <folder name="Other" id="id-c4c-folder-other" type="other">
    <element xsi:type="archimate:Junction" name="Accepted Order" id="id-c4c-element-accepted"/>
  </folder>
  <folder name="Relations" id="id-c4c-folder-relations" type="relations">
    <element xsi:type="archimate:TriggeringRelationship" id="id-c4c-relationship-1" source="id-c4c-element-operator" target="id-c4c-element-onboarding" name="starts onboarding"/>
    <element xsi:type="archimate:ServingRelationship" id="id-c4c-relationship-2" source="id-c4c-element-onboarding" target="id-c4c-element-apiService" name="requests account activation"/>
    <element xsi:type="archimate:FlowRelationship" id="id-c4c-relationship-3" source="id-c4c-element-portal" target="id-c4c-element-gateway" name="Calls trading gateway over secure API with customer and order context"/>
    <element xsi:type="archimate:FlowRelationship" id="id-c4c-relationship-4" source="id-c4c-element-gateway" target="id-c4c-element-accepted" name="validates order"/>
    <element xsi:type="archimate:TriggeringRelationship" id="id-c4c-relationship-5" source="id-c4c-element-accepted" target="id-c4c-element-matcher" name="routes accepted order"/>
    <element xsi:type="archimate:AccessRelationship" id="id-c4c-relationship-6" source="id-c4c-element-matcher" target="id-c4c-element-ledger" name="writes ledger entry"/>
    <element xsi:type="archimate:AccessRelationship" id="id-c4c-relationship-7" source="id-c4c-element-gateway" target="id-c4c-element-ledger" name="reads latest ledger state"/>
    <element xsi:type="archimate:AccessRelationship" id="id-c4c-relationship-8" source="id-c4c-element-audit" target="id-c4c-element-ledger" name="reads and writes audit snapshots"/>
    <element xsi:type="archimate:ServingRelationship" id="id-c4c-relationship-9" source="id-c4c-element-apiService" target="id-c4c-element-operator" name="serves operator workflow"/>
    <element xsi:type="archimate:InfluenceRelationship" id="id-c4c-relationship-10" source="id-c4c-element-compliance" target="id-c4c-element-regulation" name="raises"/>
    <element xsi:type="archimate:InfluenceRelationship" id="id-c4c-relationship-11" source="id-c4c-element-regulation" target="id-c4c-element-traceabilityGoal" name="motivates"/>
    <element xsi:type="archimate:RealizationRelationship" id="id-c4c-relationship-12" source="id-c4c-element-traceabilityGoal" target="id-c4c-element-auditRequirement" name="is refined by"/>
    <element xsi:type="archimate:RealizationRelationship" id="id-c4c-relationship-13" source="id-c4c-element-tradingCapability" target="id-c4c-element-gateway" name="realized by"/>
    <element xsi:type="archimate:ServingRelationship" id="id-c4c-relationship-14" source="id-c4c-element-techService" target="id-c4c-element-runtime" name="is served by"/>
    <element xsi:type="archimate:AssignmentRelationship" id="id-c4c-relationship-15" source="id-c4c-element-runtime" target="id-c4c-element-gatewayArtifact" name="deploys"/>
    <element xsi:type="archimate:CompositionRelationship" id="id-c4c-relationship-16" source="id-c4c-element-rack" target="id-c4c-element-runtime" name="contains"/>
  </folder>
