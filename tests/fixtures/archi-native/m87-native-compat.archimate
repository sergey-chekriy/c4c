<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="M87 Native Compat" id="model-m87" version="5.0.0">
  <folder name="Strategy" id="folder-strategy" type="strategy"/>
  <folder name="Business" id="folder-business" type="business">
    <element xsi:type="archimate:BusinessActor" name="User" id="actor-1"/>
  </folder>
  <folder name="Application" id="folder-application" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Orders" id="app-1"/>
    <element xsi:type="archimate:DataObject" name="Order Data" id="data-1"/>
  </folder>
  <folder name="Technology &amp; Physical" id="folder-technology" type="technology">
    <element xsi:type="archimate:Node" name="Primary Node" id="node-1"/>
    <element xsi:type="archimate:Artifact" name="Artifact" id="artifact-1"/>
  </folder>
  <folder name="Motivation" id="folder-motivation" type="motivation"/>
  <folder name="Implementation &amp; Migration" id="folder-implementation" type="implementation_migration"/>
  <folder name="Other" id="folder-other" type="other">
    <element xsi:type="archimate:Grouping" name="Boundary" id="boundary-1"/>
  </folder>
  <folder name="Relations" id="folder-relations" type="relations">
    <element xsi:type="archimate:FlowRelationship" name="Uses" id="relationship-1" source="actor-1" target="app-1"/>
    <element xsi:type="archimate:AccessRelationship" name="Reads" id="relationship-2" source="app-1" target="data-1" accessType="read"/>
    <element xsi:type="archimate:AssignmentRelationship" name="Hosts" id="relationship-3" source="node-1" target="artifact-1"/>
    <element xsi:type="archimate:CompositionRelationship" name="Contains" id="relationship-4" source="boundary-1" target="app-1"/>
  </folder>
  <folder name="Views" id="folder-views" type="diagrams">
    <element xsi:type="archimate:ArchimateDiagramModel" name="Context" id="view-1" viewpoint="applicationCooperation">
      <child xsi:type="archimate:Group" id="group-1" name="Users" fillColor="#eeeeee">
        <bounds x="20" y="20" width="220" height="160"/>
        <child xsi:type="archimate:DiagramObject" id="object-actor" archimateElement="actor-1" fillColor="#ffffb5">
          <bounds x="20" y="40" width="180" height="70"/>
          <sourceConnection xsi:type="archimate:Connection" id="connection-1" source="object-actor" target="object-app" archimateRelationship="relationship-1"/>
        </child>
      </child>
      <child xsi:type="archimate:DiagramObject" id="object-app" archimateElement="app-1" targetConnections="connection-1" fillColor="#b5ffff">
        <bounds x="300" y="60" width="180" height="80"/>
        <sourceConnection xsi:type="archimate:Connection" id="connection-2" source="object-app" target="object-data" archimateRelationship="relationship-2"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="object-data" archimateElement="data-1" targetConnections="connection-2" fillColor="#b5ffff">
        <bounds x="560" y="60" width="180" height="80"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="object-node" archimateElement="node-1" fillColor="#c9d9ff">
        <bounds x="300" y="220" width="180" height="80"/>
        <sourceConnection xsi:type="archimate:Connection" id="connection-3" source="object-node" target="object-artifact" archimateRelationship="relationship-3"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="object-artifact" archimateElement="artifact-1" targetConnections="connection-3" fillColor="#c9d9ff">
        <bounds x="560" y="220" width="180" height="80"/>
      </child>
    </element>
  </folder>
</archimate:model>
